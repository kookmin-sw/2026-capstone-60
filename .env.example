# EC2 IAM Role 사용 시 AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY는 삭제하세요.

# AWS
AWS_REGION=us-east-1
#AWS_ACCESS_KEY_ID=your_access_key
#AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 (Knowledge Base 데이터 소스)
S3_BUCKET_NAME=pj-kmucd1-10-bk
S3_PREFIX=pj-kmucd1-10-KBbk/

# Bedrock Knowledge Base
KNOWLEDGE_BASE_ID=MVJMHC0YM2

# Bedrock LLM 모델
LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
