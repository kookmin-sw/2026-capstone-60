# ── LiveKit Cloud (STT/TTS Inference 용) ─────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# ── AWS (Bedrock + Knowledge Base) ───────────────────────
# EC2 IAM Role 사용 시 아래 KEY 는 주석 유지.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ── LLM Provider 선택 ────────────────────────────────────
# bedrock : 실제 AWS Bedrock 호출 (AWS 자격증명 필요)
# mock    : AWS 없이 로컬 테스트 — 준비된 샘플 질문만 반환
LLM_PROVIDER=bedrock

# ── Bedrock LLM 모델 ─────────────────────────────────────
LLM_MODEL=us.anthropic.claude-sonnet-4-6

# ── Bedrock Knowledge Base ───────────────────────────────
# 비워두면 RAG retrieve 를 skip (Claude 단독 호출).
KNOWLEDGE_BASE_ID=
KB_TOP_K=4

# ── TTS ─────────────────────────────────────────────────
# TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc

# ── Dev-only ─────────────────────────────────────────────
# Spring dispatch 없이 콘솔로 돌릴 때 metadata fallback.
# DEV_METADATA={"sessionId":"test-1","jobRole":"BACKEND","resumeText":"이력서 원문..."}

# ── Backend 내부 API (QnA 저장용) ────────────────────────
BACKEND_INTERNAL_URL=http://localhost:8080
# SERVICE_TOKEN=your_service_token

# ── 로깅 ─────────────────────────────────────────────────
# LOG_LEVEL=INFO
