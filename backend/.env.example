# ============================================================
# 환경변수 템플릿
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 채워넣으세요.
#   cp .env.example .env
# .env 파일은 Git에 커밋되지 않습니다 (.gitignore에 등록됨).
# ============================================================

# --- Database ---
# docker-compose.yml의 POSTGRES_* 설정과 일치시키세요.
DB_URL=jdbc:postgresql://localhost:5432/interview_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- JWT ---
# 최소 32자 이상의 랜덤 문자열 사용 (HS256 알고리즘 요구사항).
# 생성 예시: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars

# --- LiveKit ---
# LiveKit Cloud 또는 로컬 서버 URL. 값은 팀 공유 문서 참고.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Internal Service Token ---
# Agent → Backend 서버 간 통신용 공유 secret.
# Agent 쪽 .env 와 동일한 값을 설정해야 합니다.
# 생성 예시: openssl rand -base64 32
INTERNAL_SERVICE_TOKEN=change-me-to-a-shared-secret

# --- LLM / Bedrock ---
# mock: MockLLMClient (default, works without AWS credentials)
# bedrock: BedrockLLMClient (real Bedrock invocation)
LLM_PROVIDER=mock

# Used when LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
LLM_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2

# --- CORS ---
# 허용할 프론트엔드 출처 (쉼표로 구분).
# 로컬 개발: http://localhost:5173,http://localhost:5174
# 프로덕션: 실제 프론트 배포 도메인으로 교체
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
